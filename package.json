{
  "name": "codex-remote-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Discord-first bridge for Codex CLI sessions over tmux.",
  "bin": {
    "cxb": "./dist/src/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "npm run typecheck",
    "setup": "node dist/src/cli/index.js setup",
    "up": "node dist/src/cli/index.js up",
    "down": "node dist/src/cli/index.js down",
    "restart": "node dist/src/cli/index.js restart",
    "status": "node dist/src/cli/index.js status",
    "doctor": "node dist/src/cli/index.js doctor",
    "register": "node dist/src/cli/index.js register",
    "start": "node dist/src/cli/index.js up",
    "test": "vitest run",
    "test:runtime": "vitest run tests/runtime.test.ts"
  },
  "dependencies": {
    "discord.js": "^14.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
